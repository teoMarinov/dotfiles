{
    "layer": "top",
    "position": "top",
    "height": 36,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 0,

    "modules-left": [
        "hyprland/workspaces"
    ],

    "modules-center": [
        "clock",
    ],

    "modules-right": [
        "pulseaudio",
        "backlight",
        "temperature",
        "cpu",
        "memory",
        "battery",
        "hyprland/language",
        "tray",
        "custom/notification",
        "custom/power"
    ],

    // ── Workspaces ──────────────────────────────────────────────
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5]
        }
    },

    // ── Clock ────────────────────────────────────────────────────
    "clock": {
        "format": "{:%H:%M %a, %b %d}",
        "tooltip": false,
    },

     "temperature": {
          "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
          "critical-threshold": 90,
          "format": "󰔏 {temperatureC}°C",
          "format-critical": "󰸁 {temperatureC}°C"
     },

    "cpu": {
       "interval": 2,
       "format": "󰻠 {usage}%",
       "tooltip-format": "{avg_frequency} GHz"
    },

    "memory": {
        "interval": 1,
        "format": "󰍛 {percentage}%",
      },

    "hyprland/language": {
        "format": "󰌌 {short}"
     },

    "battery": {
        "format": "{icon} {capacity}",
        "states": {
            "warning": 50,
            "critical": 25
          },
        "format-icons": ["🪫","🔋"],
        "format-charging": "⚡ {capacity}%",
        "format-plugged": "🔌",
      },

    "backlight": {
            "device": "amdgpu_bl1",
           "format": "{icon} {percent}%",
           "format-icons": ["󰃞", "󰃟", "󰃠"],
           "on-scroll-up": "brightnessctl -d amdgpu_bl1 -e4 -n2 set 5%+",
           "on-scroll-down": "brightnessctl -d amdgpu_bl1 -e4 -n2 set 5%-",
           "tooltip": false
      },

    // ── Media (MPRIS) ────────────────────────────────────────────
    "mpris": {
        "format": "<span size='large'>{player_icon}</span> {title}",
        "format-paused": "<span size='large'>{status_icon}</span> {title}",
        "player-icons": {
            "default": "󰏤",
            "spotify": "󰓇"
        },
        "status-icons": {
            "paused": "󰐊"
        },
        "max-length": 30,
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip-format": "{player} — {title} by {artist}"
    },

    // ── Audio ────────────────────────────────────────────────────
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 {volume}%",
        "format-icons": {
            "default": ["󰖀", "󰕾"]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
        "tooltip": false
    },

    "group": {
        "orientation": "horizontal",
        "modules": ["temperature", "cpu", "memory"],
        "on-click": "kitty btop"
      },

    // ── System Tray ──────────────────────────────────────────────
    "tray": {
        "icon-size": 14,
        "spacing": 10,
        "show-passive-items": true
    },

    // ── Notifications (requires swaync) ──────────────────────────
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "󰂚",
            "none": "󰂜",
            "dnd-notification": "󰂛",
            "dnd-none": "󰂛",
            "inhibited-notification": "󰂚",
            "inhibited-none": "󰂜",
            "dnd-inhibited-notification": "󰂛",
            "dnd-inhibited-none": "󰂛"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    // ── Power ────────────────────────────────────────────────────
    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "$HOME/.config/hypr/scripts/PowerMenu.sh"
    }
}
